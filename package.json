{
  "name": "shared-costs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:migrate": "node --env-file-if-exists=.env.local scripts/db-migrate.mjs",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\" \"!.next/**\"",
    "lint:ts": "eslint . --ext .ts,.tsx",
    "lint:css": "stylelint \"**/*.{css,pcss,scss}\" --allow-empty-input",
    "format": "prettier --write \"**/*.md\" \"**/*.{ts,tsx,js,jsx,json}\" \"**/*.{css,pcss,scss}\"",
    "format:check": "prettier --check \"**/*.md\" \"**/*.{ts,tsx,js,jsx,json}\" \"**/*.{css,pcss,scss}\"",
    "format:md": "prettier --write \"**/*.md\"",
    "format:ts": "prettier --write \"**/*.{ts,tsx,js,jsx,json}\"",
    "format:css": "prettier --write \"**/*.{css,pcss,scss}\"",
    "format:check:md": "prettier --check \"**/*.md\"",
    "format:check:ts": "prettier --check \"**/*.{ts,tsx,js,jsx,json}\"",
    "format:check:css": "prettier --check \"**/*.{css,pcss,scss}\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "markdownlint-cli2": "^0.18.0",
    "prettier": "^3.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^39.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
